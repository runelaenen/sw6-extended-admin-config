{% block laenen_column_configurator %}
<div class="laenen-column-configurator">

    <div
        v-for="(column, index) in columnList"
        :key="index"
        class="laenen-column-configurator__row"
    >
        <sw-container
            columns="2fr 1fr 1fr 1fr 80px 160px"
            gap="0 16px"
            align="center"
        >
            <mt-text-field
                :model-value="column.path"
                label="Field path"
                placeholder="e.g. orderCustomer.email"
                @update:model-value="onPathChange(index, $event)"
            />

            <mt-text-field
                :model-value="column.label"
                label="Column label"
                placeholder="e.g. Customer e-mail"
                @update:model-value="onLabelChange(index, $event)"
            />

            <sw-select-field
                :model-value="column.format || ''"
                :options="formatOptions"
                label="Format"
                @update:model-value="onFormatChange(index, $event)"
            />

            <mt-text-field
                :model-value="column.afterColumn || ''"
                label="After column"
                placeholder="e.g. orderNumber"
                @update:model-value="onAfterColumnChange(index, $event)"
            />

            <mt-checkbox
                :checked="column.active"
                label="Active"
                @update:checked="onActiveChange(index, $event)"
            />

            <div class="laenen-column-configurator__controls">
                <mt-button
                    size="small"
                    :disabled="index === 0"
                    @click="moveUp(index)"
                >↑</mt-button>
                <mt-button
                    size="small"
                    :disabled="index >= columnList.length - 1"
                    @click="moveDown(index)"
                >↓</mt-button>
                <mt-button
                    size="small"
                    variant="critical"
                    @click="removeColumn(index)"
                >✕</mt-button>
            </div>
        </sw-container>
    </div>

    <mt-button
        size="small"
        class="laenen-column-configurator__add"
        @click="addColumn"
    >+ Add column</mt-button>

</div>
{% endblock %}

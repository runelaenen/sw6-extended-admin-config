{% block laenen_filter_configurator %}
<div class="laenen-filter-configurator">

    <div
        v-for="(filter, index) in filterList"
        :key="index"
        class="laenen-filter-configurator__row"
    >
        <sw-container
            columns="2fr 1fr 80px 160px"
            gap="0 16px"
            align="center"
        >
            <mt-text-field
                :model-value="filter.property"
                label="Field path"
                placeholder="e.g. orderCustomer.email"
                @update:model-value="onPropertyChange(index, $event)"
            />

            <mt-text-field
                :model-value="filter.label"
                label="Filter label"
                placeholder="e.g. Customer e-mail"
                @update:model-value="onLabelChange(index, $event)"
            />

            <mt-checkbox
                :checked="filter.active"
                label="Active"
                @update:checked="onActiveChange(index, $event)"
            />

            <div class="laenen-filter-configurator__controls">
                <mt-button
                    size="small"
                    :disabled="index === 0"
                    @click="moveUp(index)"
                >↑</mt-button>
                <mt-button
                    size="small"
                    :disabled="index >= filterList.length - 1"
                    @click="moveDown(index)"
                >↓</mt-button>
                <mt-button
                    size="small"
                    variant="critical"
                    @click="removeFilter(index)"
                >✕</mt-button>
            </div>
        </sw-container>
    </div>

    <mt-button
        size="small"
        class="laenen-filter-configurator__add"
        @click="addFilter"
    >+ Add filter</mt-button>

</div>
{% endblock %}
